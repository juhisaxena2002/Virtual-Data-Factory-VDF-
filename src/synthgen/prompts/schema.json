{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SyntheticDataSpec",
  "type": "object",
  "required": ["dataset_name", "fields"],
  "additionalProperties": false,
  "properties": {
    "dataset_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "description": "Snake_case identifier for the dataset."
    },
    "count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 200,
      "description": "Number of rows to generate. Phase 1 hard-cap is 200."
    },
    "stream_interval_sec": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Optional. Seconds between records when streaming. Set only if the prompt mentions a streaming rate or cadence."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": { "$ref": "#/$defs/Field" }
    },
    "correlations": {
      "type": "array",
      "maxItems": 20,
      "description": "Optional. Inter-field correlations. Omit for independent fields.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/DerivedCorrelation" },
          { "$ref": "#/$defs/MultivariateCorrelation" }
        ]
      }
    }
  },
  "$defs": {
    "Field": {
      "type": "object",
      "required": ["name", "type", "provider"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Snake_case column name."
        },
        "type": {
          "enum": ["string", "int", "float", "bool", "datetime", "uuid"]
        },
        "provider": {
          "type": "string",
          "description": "Faker / Mimesis / built-in provider name. Validated against allow-list at runtime."
        },
        "args": {
          "type": "object",
          "description": "Keyword arguments passed to the provider."
        },
        "distribution": {
          "enum": ["uniform", "normal", "exponential", "choice", "sequential"]
        },
        "anomalies": {
          "type": "array",
          "items": { "$ref": "#/$defs/Anomaly" }
        }
      }
    },
    "DerivedCorrelation": {
      "type": "object",
      "required": ["mode", "source", "target", "slope"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "derived" },
        "source": { "type": "string", "description": "Field whose value drives the target." },
        "target": { "type": "string", "description": "Field whose value is computed from source." },
        "slope": { "type": "number" },
        "intercept": { "type": "number" },
        "noise_std": { "type": "number", "minimum": 0 },
        "min_value": { "type": "number" },
        "max_value": { "type": "number" }
      }
    },
    "MultivariateCorrelation": {
      "type": "object",
      "required": ["mode", "fields", "correlation"],
      "additionalProperties": false,
      "properties": {
        "mode": { "const": "multivariate" },
        "fields": {
          "type": "array",
          "minItems": 2,
          "maxItems": 20,
          "items": { "type": "string" }
        },
        "correlation": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "items": { "type": "number", "minimum": -1, "maximum": 1 }
          }
        }
      }
    },
    "Anomaly": {
      "type": "object",
      "required": ["type", "rate"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "null",
            "outlier",
            "stuck_value",
            "spike",
            "duplicate",
            "drift",
            "invalid_format"
          ]
        },
        "rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fraction of rows affected, 0.0–1.0."
        },
        "magnitude": {
          "type": "number",
          "description": "Scaling factor; meaning depends on anomaly type."
        },
        "value": {
          "description": "Used by stuck_value; otherwise omitted."
        }
      }
    }
  }
}
